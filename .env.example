# 共享认证
APP_ENV=development
JWT_SECRET=change-me-in-env
AUTH_TOKEN_TTL_MINUTES=720

# 本地演示账号
# 非本地环境运行前请务必覆盖以下默认值
ADMIN_USER_ID=11111111-1111-1111-1111-111111111111
ADMIN_EMAIL=admin@local
ADMIN_PASSWORD=ChangeMe123!
MEMBER_USER_ID=22222222-2222-2222-2222-222222222222
MEMBER_EMAIL=member@local
MEMBER_PASSWORD=ChangeMe123!

# 日志
LOG_LEVEL=INFO

# PostgreSQL
POSTGRES_DB=postgres
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag
POSTGRES_HOST_PORT=5432
KB_DATABASE_DSN=postgresql://rag:rag@postgres:5432/kb_app
GATEWAY_DATABASE_DSN=postgresql://rag:rag@postgres:5432/gateway_app

# 网关路由
GATEWAY_TIMEOUT_SECONDS=180
GATEWAY_HOST_PORT=8080
KB_HOST_PORT=8300
KB_SERVICE_URL=http://kb-service:8200
VITE_GATEWAY_ORIGIN=http://localhost:8080

# 对象存储 / MinIO
OBJECT_STORAGE_ENDPOINT=http://minio:9000
OBJECT_STORAGE_PUBLIC_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_HOST_PORT=9000
OBJECT_STORAGE_CONSOLE_HOST_PORT=9001
OBJECT_STORAGE_ACCESS_KEY=minioadmin
OBJECT_STORAGE_SECRET_KEY=minioadmin
OBJECT_STORAGE_BUCKET=rag-assets
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
VISUAL_ASSET_URL_EXPIRES_SECONDS=3600

# 向量嵌入
EMBEDDING_PROVIDER=local
EMBEDDING_LOCAL_BACKEND=projection
EMBEDDING_MODEL=local-projection-512
EMBEDDING_API_URL=
EMBEDDING_API_KEY=
EMBEDDING_TIMEOUT_SECONDS=60
EMBEDDING_BATCH_SIZE=64

# 上传 / 聊天默认值
UPLOAD_PART_EXPIRES_SECONDS=3600
CHAT_MAX_EVIDENCE=8
CHAT_HISTORY_MESSAGES=8
VISUAL_ASSET_URL_EXPIRES_SECONDS=3600

# Worker 运行时
KB_BLOB_ROOT=/data/kb
KB_WORKER_POLL_SECONDS=2
KB_SECTION_BATCH_SIZE=50
KB_CHUNK_BATCH_SIZE=500
VISION_ENABLED=false
VISION_PRIMARY_PROVIDER=local-http
VISION_FALLBACK_PROVIDER=openai-compatible
VISION_LOCAL_URL=
VISION_LOCAL_TIMEOUT_SECONDS=20
VISION_EXTERNAL_BASE_URL=
VISION_EXTERNAL_API_KEY=
VISION_EXTERNAL_MODEL=
VISION_EXTERNAL_TIMEOUT_SECONDS=60
VISION_MAX_ASSETS_PER_DOCUMENT=64
VISION_PRESIGN_TTL_SECONDS=3600
VISION_PROVIDER=local
VISION_FALLBACK_PROVIDER=
VISION_TIMEOUT_SECONDS=60
VISION_THUMBNAIL_MAX_SIDE=320
VISION_EXTERNAL_BASE_URL=
VISION_EXTERNAL_API_KEY=
VISION_EXTERNAL_MODEL=
VISION_LOCAL_LANGUAGE_HINT=ch
VISION_OCR_PROMPT=请提取图片中的可见文字，保留换行，忽略无意义装饰。

# LLM 回答生成
LLM_ENABLED=true
LLM_PROVIDER=openai-compatible
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=
LLM_MODEL=qwen3.5-plus
LLM_COMMON_KNOWLEDGE_MODEL=
LLM_TIMEOUT_SECONDS=120
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048
LLM_COMMON_KNOWLEDGE_MAX_TOKENS=512
LLM_COMMON_KNOWLEDGE_HISTORY_MESSAGES=4
LLM_COMMON_KNOWLEDGE_HISTORY_CHARS=400
LLM_SYSTEM_PROMPT=你是一个简洁可靠的中文助手。除非用户另有要求，请使用中文回答。
LLM_EXTRA_BODY_JSON={}
LLM_PRICE_CURRENCY=CNY
LLM_PRICE_TIERS_JSON=[{"max_input_tokens":131072,"input_price_per_1k_tokens":0.0008,"output_price_per_1k_tokens":0.0048},{"max_input_tokens":262144,"input_price_per_1k_tokens":0.002,"output_price_per_1k_tokens":0.012},{"max_input_tokens":1048576,"input_price_per_1k_tokens":0.004,"output_price_per_1k_tokens":0.024}]
LLM_INPUT_PRICE_PER_1K_TOKENS=0.0008
LLM_OUTPUT_PRICE_PER_1K_TOKENS=0.0048

# Qdrant / FastEmbed
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=kb-evidence
QDRANT_PREFER_GRPC=false
QDRANT_TIMEOUT_SECONDS=10
QDRANT_HOST_PORT=6333
QDRANT_GRPC_HOST_PORT=6334
FASTEMBED_MODEL_NAME=BAAI/bge-small-zh-v1.5
FASTEMBED_SPARSE_MODEL_NAME=Qdrant/bm25
FASTEMBED_VECTOR_SIZE=512
FASTEMBED_THREADS=4
FASTEMBED_CACHE_DIR=/data/kb/fastembed-cache
FASTEMBED_BATCH_SIZE=64

# 网关迁移期间仍支持旧版别名

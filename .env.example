# Go API 基础配置
HTTP_ADDR=:8080
POSTGRES_DSN=postgres://rag:rag@postgres:5432/rag?sslmode=disable
RAG_SERVICE_URL=http://py-rag-service:8000
MAX_UPLOAD_BYTES=524288000
AUTH_TOKEN_TTL_MINUTES=120
REDIS_URL=redis://redis:6379/0
INGEST_QUEUE_KEY=ingest_jobs

# 默认开发账号，仅用于本地演示
ADMIN_USER_ID=11111111-1111-1111-1111-111111111111
ADMIN_EMAIL=admin@local
ADMIN_PASSWORD=ChangeMe123!
MEMBER_USER_ID=22222222-2222-2222-2222-222222222222
MEMBER_EMAIL=member@local
MEMBER_PASSWORD=ChangeMe123!

# PostgreSQL
POSTGRES_DB=rag
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag

# MinIO / S3
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_ENDPOINT=minio:9000
S3_PUBLIC_ENDPOINT=localhost:19000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=rag-raw
S3_USE_SSL=false
S3_PRESIGN_EXPIRY_MINUTES=30

# 本地 Ollama 地址
# Docker 容器内访问宿主机 Ollama 时，Windows / macOS / Docker Desktop 推荐使用 host.docker.internal。
# 如果你是直接在宿主机启动 Python 服务，可改成 http://127.0.0.1:11434/v1。
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1

# 对话模型配置
# 可选 provider: openai | deepseek | moonshot | qwen | zhipu | siliconflow | groq | together | fireworks | volcengine | ollama | custom
# 如果你暂时不需要 LLM 摘要，可先保留 CHAT_API_KEY 为空，系统会回退为基于证据片段的回答。
CHAT_PROVIDER=qwen
# 仅当 provider=custom 或需要覆盖平台默认地址时填写。
CHAT_BASE_URL=
CHAT_API_KEY=
# 常见示例:
# openai: gpt-4o-mini / gpt-4.1-mini
# deepseek: deepseek-chat / deepseek-reasoner
# moonshot: moonshot-v1-8k
# qwen: qwen3.5-plus / qwen-plus / qwen-turbo / qwen-max
# zhipu: glm-4-plus / glm-4-flash
# groq: llama-3.3-70b-versatile
# together: meta-llama/Llama-3.3-70B-Instruct-Turbo
# ollama: qwen2.5:14b
CHAT_MODEL=qwen3.5-plus

# Embedding 模型配置
# 默认走本地 Ollama。CPU 为主的本机环境可优先考虑 embeddinggemma:latest，吞吐通常更高。
# 可选 provider: openai | deepseek | moonshot | qwen | zhipu | siliconflow | groq | together | fireworks | volcengine | ollama | gemini | custom
EMBEDDING_PROVIDER=ollama
# 留空时会自动使用 OLLAMA_BASE_URL；只有接入其他兼容接口时才需要单独填写。
EMBEDDING_BASE_URL=
# Ollama / 大多数本地兼容服务无需 API Key；云厂商请按平台要求填写。
EMBEDDING_API_KEY=
# 常见示例:
# openai: text-embedding-3-small / text-embedding-3-large
# deepseek: deepseek-embedding
# qwen: text-embedding-v3
# zhipu: embedding-3
# siliconflow: BAAI/bge-m3
# ollama: embeddinggemma:latest / andersc/qwen3-embedding:0.6b / nomic-embed-text
# gemini: gemini-embedding-001
EMBEDDING_MODEL=embeddinggemma:latest
EMBEDDING_DIM=0
EMBEDDING_BATCH_SIZE=32
EMBEDDING_BATCH_MAX_CHARS=64000
EMBEDDING_KEEP_ALIVE=1h
EMBEDDING_TIMEOUT_SECONDS=120
LONG_TEXT_MODE_ENABLED=true
LONG_TEXT_THRESHOLD_CHARS=250000
LONG_TEXT_CHUNK_SIZE=2048
LONG_TEXT_CHUNK_OVERLAP=32
LONG_TEXT_EMBEDDING_BATCH_SIZE=96
LONG_TEXT_EMBEDDING_BATCH_MAX_CHARS=256000
LONG_TEXT_SPARSE_ONLY_ENABLED=true
LONG_TEXT_SPARSE_ONLY_THRESHOLD_CHARS=2000000
LONG_TEXT_SPARSE_CHUNK_CHARS=4096
LONG_TEXT_SPARSE_CHUNK_OVERLAP_CHARS=256
SECTION_SUMMARY_THRESHOLD_CHARS=250000
SECTION_SUMMARY_CHARS=2000
METADATA_SAMPLING_MAX_CHARS=120000
SEARCH_TERMS_MAX_PER_CHUNK=64
# 0 表示自动使用模型原生维度，兼容不同 embedding 模型更稳。
EMBEDDING_DIM=0
# embeddinggemma 在 CPU 环境里通常更适合用较大的批次。
EMBEDDING_BATCH_SIZE=32
# 放宽单批总字符，尽量让批量优势发挥出来；若超时再回退到 48000 或 24000。
EMBEDDING_BATCH_MAX_CHARS=64000
# 让本地 Ollama 模型常驻一段时间，减少反复加载模型的开销。
EMBEDDING_KEEP_ALIVE=1h
# embedding 单独超时。大批次本地模型通常需要显著高于聊天接口的超时。
EMBEDDING_TIMEOUT_SECONDS=120

# 模型调用重试与超时
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2
LLM_RETRY_DELAY_MILLISECONDS=600

# RAG 检索主参数
RAG_RETRIEVAL_TOP_N=24
RAG_RERANK_TOP_K=8
RAG_SOURCE_SENTENCE_LIMIT=6
RAG_EVIDENCE_MIN_SCORE=0.05
RAG_COMMON_KNOWLEDGE_MAX_RATIO=0.15

# 混合检索权重
# 两个权重会在服务启动时自动归一化，总和不需要手工保证为 1。
HYBRID_SEARCH_DENSE_WEIGHT=0.7
HYBRID_SEARCH_SPARSE_WEIGHT=0.3

# 多查询检索
MULTI_QUERY_ENABLED=false
MULTI_QUERY_MAX_VARIANTS=3
MULTI_QUERY_TIMEOUT_MS=500

# 重排模型
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_TOP_K=8

# 查询缓存
QUERY_CACHE_ENABLED=true
QUERY_CACHE_TTL_HOURS=24
QUERY_CACHE_MAX_SIZE=10000
SPARSE_RETRIEVAL_ENABLED=true
SPARSE_CACHE_TTL_SECONDS=600
SPARSE_CACHE_MAX_SCOPES=16
SECTION_TOP_K=8
SECTION_EXPAND_CHUNK_LIMIT=6
RAG_EVIDENCE_COVERAGE_THRESHOLD=0.45

# 上下文压缩
CONTEXT_COMPRESSOR_ENABLED=false
CONTEXT_COMPRESSOR_MODEL=llm
CONTEXT_MAX_TOKENS=3200

# 文档切块
# embeddinggemma 上下文较短，1536 比 2048 更稳，仍能显著减少 chunk 数。
DEFAULT_CHUNK_SIZE=1536
# overlap 越小，重复 embedding 越少；这里保留适度重叠兼顾召回质量。
DEFAULT_CHUNK_OVERLAP=96

# 意图识别
INTENT_CLASSIFICATION_ENABLED=true

# 元数据增强
METADATA_ENHANCEMENT_ENABLED=true
MAX_KEYWORDS=5

# Worker / Qdrant
WORKER_POLL_INTERVAL_SECONDS=5
WORKER_MAX_RETRIES=3
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=rag_chunks

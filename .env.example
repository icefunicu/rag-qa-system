# 运行环境标识。开发环境通常填 development，正式环境通常填 production。
APP_ENV=development

# JWT 签名密钥。所有登录态 token 都依赖它，正式环境必须替换成高强度随机值。
JWT_SECRET=change-me-in-env

# 登录 token 的有效期，单位分钟。
AUTH_TOKEN_TTL_MINUTES=720

# 本地管理员账号的固定用户 ID。仅用于本地演示和初始化。
ADMIN_USER_ID=11111111-1111-1111-1111-111111111111

# 本地管理员登录邮箱。
ADMIN_EMAIL=admin@local

# 本地管理员密码。正式环境不要使用默认值。
ADMIN_PASSWORD=ChangeMe123!

# 本地普通成员账号的固定用户 ID。仅用于本地演示和初始化。
MEMBER_USER_ID=22222222-2222-2222-2222-222222222222

# 本地普通成员登录邮箱。
MEMBER_EMAIL=member@local

# 本地普通成员密码。正式环境不要使用默认值。
MEMBER_PASSWORD=ChangeMe123!

# 日志级别。常用值有 DEBUG、INFO、WARNING、ERROR。
LOG_LEVEL=INFO

# PostgreSQL 默认数据库名。主要用于 docker compose 初始化容器。
POSTGRES_DB=postgres

# PostgreSQL 用户名。主要用于 docker compose 初始化容器。
POSTGRES_USER=rag

# PostgreSQL 密码。主要用于 docker compose 初始化容器。
POSTGRES_PASSWORD=rag

# PostgreSQL 暴露到宿主机的端口。
POSTGRES_HOST_PORT=5432

# 知识库服务连接 PostgreSQL 的 DSN。
KB_DATABASE_DSN=postgresql://rag:rag@postgres:5432/kb_app

# 网关服务连接 PostgreSQL 的 DSN。
GATEWAY_DATABASE_DSN=postgresql://rag:rag@postgres:5432/gateway_app

# 网关调用下游服务的超时时间，单位秒。
GATEWAY_TIMEOUT_SECONDS=180

# 网关对宿主机暴露的 HTTP 端口。
GATEWAY_HOST_PORT=8080

# 知识库服务对宿主机暴露的 HTTP 端口。
KB_HOST_PORT=8300

# 网关在容器网络内访问知识库服务的地址。
KB_SERVICE_URL=http://kb-service:8200

# 前端访问网关时使用的公网或本地地址。
VITE_GATEWAY_ORIGIN=http://localhost:8080

# 多知识库检索时，网关最多并发扇出多少个作用域。
GATEWAY_RETRIEVAL_FANOUT_LIMIT=4

# 网关幂等键保留时长，单位小时。
GATEWAY_IDEMPOTENCY_TTL_HOURS=24

# 网关全局同时处理聊天请求的上限。
GATEWAY_CHAT_MAX_IN_FLIGHT_GLOBAL=32

# 单个用户同时发起聊天请求的上限。
GATEWAY_CHAT_MAX_IN_FLIGHT_PER_USER=4

# 单个会话允许累计的成本预算。0 表示不限制。
GATEWAY_CHAT_SESSION_COST_BUDGET=0

# MinIO 或兼容 S3 的内网访问地址。服务之间上传下载用它。
OBJECT_STORAGE_ENDPOINT=http://minio:9000

# 前端或浏览器访问对象存储时使用的公开地址。
OBJECT_STORAGE_PUBLIC_ENDPOINT=http://localhost:9000

# MinIO API 暴露到宿主机的端口。
OBJECT_STORAGE_HOST_PORT=9000

# MinIO Console 暴露到宿主机的端口。
OBJECT_STORAGE_CONSOLE_HOST_PORT=9001

# 对象存储访问账号。
OBJECT_STORAGE_ACCESS_KEY=minioadmin

# 对象存储访问密码。
OBJECT_STORAGE_SECRET_KEY=minioadmin

# 系统保存上传文件、视觉资产和中间产物时使用的桶名。
OBJECT_STORAGE_BUCKET=rag-assets

# 对象存储区域。MinIO 本地通常保持 us-east-1 即可。
OBJECT_STORAGE_REGION=us-east-1

# 允许浏览器直接访问对象存储的来源列表，逗号分隔。
OBJECT_STORAGE_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 视觉资产预签名 URL 的有效期，单位秒。
VISUAL_ASSET_URL_EXPIRES_SECONDS=3600

# 向量化提供方。默认 local，表示走本地投影或本地 embedding 逻辑。
EMBEDDING_PROVIDER=local

# 本地 embedding 后端类型。当前默认 projection。
EMBEDDING_LOCAL_BACKEND=projection

# embedding 模型名称或逻辑名。
EMBEDDING_MODEL=local-projection-512

# 当 EMBEDDING_PROVIDER 为远程服务时使用的 API 地址。
EMBEDDING_API_URL=

# 当 EMBEDDING_PROVIDER 为远程服务时使用的 API 密钥。
EMBEDDING_API_KEY=

# embedding 请求超时时间，单位秒。
EMBEDDING_TIMEOUT_SECONDS=60

# embedding 批量大小。值越大吞吐越高，但内存占用也更高。
EMBEDDING_BATCH_SIZE=64

# 重排提供方。建议从 heuristic 开始；接外部 rerank 服务时再改。
RERANK_PROVIDER=heuristic

# 外部 rerank 服务地址。仅在使用 external-cross-encoder 时需要。
RERANK_API_BASE_URL=

# 外部 rerank 服务密钥。仅在使用 external-cross-encoder 时需要。
RERANK_API_KEY=

# 外部 rerank 模型名。仅在使用 external-cross-encoder 时需要。
RERANK_MODEL=

# rerank 调用超时时间，单位秒。
RERANK_TIMEOUT_SECONDS=20

# 进入 rerank 的候选数上限。
RERANK_TOP_N=12

# 发送给外部 rerank 服务的额外 JSON 参数。
RERANK_EXTRA_BODY_JSON={}

# 分片上传预签名地址的有效期，单位秒。
UPLOAD_PART_EXPIRES_SECONDS=3600

# 单次回答最多引用多少条证据。
CHAT_MAX_EVIDENCE=8

# 聊天历史最多回带多少条消息。
CHAT_HISTORY_MESSAGES=8

# 知识库服务在本地磁盘保存临时数据和缓存的根目录。
KB_BLOB_ROOT=/data/kb

# Worker 轮询待处理任务的时间间隔，单位秒。
KB_WORKER_POLL_SECONDS=2

# 文档切 section 的批处理大小。
KB_SECTION_BATCH_SIZE=50

# 文档切 chunk 的批处理大小。
KB_CHUNK_BATCH_SIZE=500

# Worker 抢占任务后的租约时长，单位秒。
KB_WORKER_LEASE_SECONDS=300

# Worker 暴露 metrics 的端口。
KB_WORKER_METRICS_PORT=9300

# stack-init 等待依赖服务就绪时的重试间隔，单位秒。
STACK_INIT_RETRY_SECONDS=2

# stack-init 等待依赖服务就绪时的最大重试次数。
STACK_INIT_RETRY_COUNT=30

# 知识库服务幂等键保留时长，单位小时。
KB_IDEMPOTENCY_TTL_HOURS=24

# 单个 ingest 作业的最大重试次数。
KB_INGEST_MAX_ATTEMPTS=5

# 知识库查询全局并发上限。
KB_QUERY_MAX_IN_FLIGHT_GLOBAL=64

# 单个用户的知识库查询并发上限。
KB_QUERY_MAX_IN_FLIGHT_PER_USER=8

# OCR 首选提供方。local 表示本地 Tesseract。
VISION_PROVIDER=local

# OCR 回退提供方。external 表示调用外部视觉模型。
VISION_FALLBACK_PROVIDER=external

# 本地 Tesseract 可执行文件名或路径。
VISION_TESSERACT_CMD=tesseract

# 本地 Tesseract 语言包。中文场景建议至少包含 chi_sim。
VISION_TESSERACT_LANG=eng+chi_sim

# 外部视觉模型 API 地址。留空表示不启用外部 OCR。
VISION_API_BASE_URL=

# 外部视觉模型 API 密钥。
VISION_API_KEY=

# 外部视觉模型名称。
VISION_MODEL=

# OCR 或视觉模型调用超时时间，单位秒。
VISION_TIMEOUT_SECONDS=60

# 图片最小边长阈值，太小的图片会被忽略。
VISION_MIN_EDGE_PX=120

# OCR 结果至少要有多少字符才认为有效。
VISION_MIN_TEXT_CHARS=6

# 单个文档最多抽取多少个视觉资产。
VISION_MAX_ASSETS_PER_DOCUMENT=48

# 生成缩略图时的最大边长。
VISION_THUMBNAIL_MAX_EDGE_PX=360

# 是否启用 LLM 生成。
LLM_ENABLED=true

# LLM 提供方。当前默认使用 OpenAI 兼容接口。
LLM_PROVIDER=openai-compatible

# LLM API 基础地址。
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# LLM API 密钥。正式环境必须填写。
LLM_API_KEY=

# 默认回答模型。
LLM_MODEL=qwen3.5-plus

# 常识兜底回答可单独指定一个更便宜的模型；留空则复用 LLM_MODEL。
LLM_COMMON_KNOWLEDGE_MODEL=

# LLM 调用超时时间，单位秒。
LLM_TIMEOUT_SECONDS=120

# 默认温度。
LLM_TEMPERATURE=0.7

# 默认最大输出 token 数。
LLM_MAX_TOKENS=2048

# 常识回答最大输出 token 数。
LLM_COMMON_KNOWLEDGE_MAX_TOKENS=512

# 常识回答最多回带多少条历史消息。
LLM_COMMON_KNOWLEDGE_HISTORY_MESSAGES=4

# 常识回答最多回带多少个历史字符。
LLM_COMMON_KNOWLEDGE_HISTORY_CHARS=400

# 默认系统提示词。
LLM_SYSTEM_PROMPT=你是一个简洁可靠的中文助手。除非用户另有要求，否则请使用中文回答。

# 发送给 LLM 的额外 JSON 参数。
LLM_EXTRA_BODY_JSON={}

# 按 route_key 切换模型的路由配置 JSON。留空表示不做路由覆盖。
LLM_MODEL_ROUTING_JSON={}

# Prompt 注册表文件路径。想把 prompt 配到单独文件时使用。
PROMPT_REGISTRY_PATH=

# Prompt 注册表 JSON。想直接通过环境变量覆盖 prompt 时使用。
PROMPT_REGISTRY_JSON={}

# 成本统计使用的货币单位。
LLM_PRICE_CURRENCY=CNY

# 阶梯定价配置 JSON。
LLM_PRICE_TIERS_JSON=[{"max_input_tokens":131072,"input_price_per_1k_tokens":0.0008,"output_price_per_1k_tokens":0.0048},{"max_input_tokens":262144,"input_price_per_1k_tokens":0.002,"output_price_per_1k_tokens":0.012},{"max_input_tokens":1048576,"input_price_per_1k_tokens":0.004,"output_price_per_1k_tokens":0.024}]

# 平铺输入单价。只有在不配置阶梯定价时才直接使用。
LLM_INPUT_PRICE_PER_1K_TOKENS=0.0008

# 平铺输出单价。只有在不配置阶梯定价时才直接使用。
LLM_OUTPUT_PRICE_PER_1K_TOKENS=0.0048

# Qdrant HTTP 地址。
QDRANT_URL=http://qdrant:6333

# Qdrant API 密钥。默认本地可留空。
QDRANT_API_KEY=

# Qdrant 集合名。
QDRANT_COLLECTION=kb-evidence

# 是否优先使用 Qdrant gRPC。
QDRANT_PREFER_GRPC=false

# Qdrant 请求超时时间，单位秒。
QDRANT_TIMEOUT_SECONDS=10

# Qdrant HTTP 暴露到宿主机的端口。
QDRANT_HOST_PORT=6333

# Qdrant gRPC 暴露到宿主机的端口。
QDRANT_GRPC_HOST_PORT=6334

# FastEmbed 稠密向量模型名。
FASTEMBED_MODEL_NAME=BAAI/bge-small-zh-v1.5

# FastEmbed 稀疏检索模型名。
FASTEMBED_SPARSE_MODEL_NAME=Qdrant/bm25

# 向量维度。需要与 embedding 输出一致。
FASTEMBED_VECTOR_SIZE=512

# FastEmbed 线程数。
FASTEMBED_THREADS=4

# FastEmbed 缓存目录。
FASTEMBED_CACHE_DIR=/data/kb/fastembed-cache

# FastEmbed 批量大小。
FASTEMBED_BATCH_SIZE=64

# 允许本地目录连接器访问的白名单根目录。Windows 用分号分隔，Linux/macOS 用冒号分隔。
KB_LOCAL_CONNECTOR_ROOTS=

# 本地目录连接器单次最多处理多少个支持格式文件。
KB_LOCAL_CONNECTOR_MAX_FILES=256

# 是否启用 Notion 连接器。
KB_NOTION_CONNECTOR_ENABLED=false

# Notion integration token。
KB_NOTION_API_TOKEN=

# Notion API 基础地址。一般保持官方默认值即可。
KB_NOTION_API_BASE_URL=https://api.notion.com/v1

# Notion API 版本。
KB_NOTION_API_VERSION=2022-06-28

# Notion 连接器单次最多同步多少个页面。
KB_NOTION_CONNECTOR_MAX_PAGES=32

# 飞书 URL 类连接器读取鉴权头时使用的环境变量值示例。
FEISHU_DOC_AUTH=

# 钉钉 URL 类连接器读取鉴权头时使用的环境变量值示例。
DINGTALK_DOC_AUTH=

# SQL 连接器读取数据库连接串时使用的环境变量值示例。
REPORTING_DB_DSN=
